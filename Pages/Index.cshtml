@page
@model IndexModel
@{
    ViewData["Title"] = "Главная - " + Model.StoreName;
}

<div class="container mt-5">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold text-primary">🚀 @Model.StoreName</h1>
        <p class="lead">Демонстрация 5 порождающих паттернов проектирования в реальном времени</p>
        <hr />
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-dark text-white">
                    <h5 class="mb-0">📜 Лог операций магазина (Singleton History)</h5>
                </div>
                <div class="card-body" style="background-color: #f8f9fa; max-height: 500px; overflow-y: auto;">
                    @if (Model.ShopHistory.Count == 0)
                    {
                        <p class="text-muted">История пуста. Обновите страницу, чтобы запустить паттерны.</p>
                    }
                    else
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var record in Model.ShopHistory)
                            {
                                <li class="list-group-item bg-transparent border-bottom">
                                    <span class="badge bg-info text-dark me-2">Info</span> @record
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm border-primary mb-4">
                <div class="card-body">
                    <h5 class="card-title text-primary font-weight-bold">Как это работает?</h5>
                    <p class="card-text small">
                        Каждое обновление страницы заново инициализирует:
                        <br />• <b>Abstract Factory</b> (Товары)
                        <br />• <b>Builder</b> (Сборка ПК)
                        <br />• <b>Factory Method</b> (Логистика)
                        <br />• <b>Prototype</b> (Клонирование)
                        <br />Все данные сохраняются в <b>Singleton</b>.
                    </p>
                    <a href="/" class="btn btn-primary w-100">Обновить страницу</a>
                </div>
            </div>

            <div class="alert alert-secondary shadow-sm">
                <strong>Статус системы:</strong>
                <br />Проект: OnlineShop Web
                <br />Версия: 2.0 (Scaled)
            </div>
        </div>
    </div>
</div>